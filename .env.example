# ============================================
# VayuDrishti (वायुदृष्टि) Environment Variables
# ============================================
#
# SETUP:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in each REQUIRED value below.
#   3. NEVER commit .env.local to version control.
#
# LEGEND:
#   [REQUIRED]  — App will fail to start without this.
#   [OPTIONAL]  — Feature-gated or has a sensible default.
#   [SERVER]    — Server-side only. Never prefix with NEXT_PUBLIC_.
#   [CLIENT]    — Exposed to the browser via NEXT_PUBLIC_ prefix.
#

# ============================================
# Firebase Configuration  [REQUIRED] [CLIENT]
# ============================================
# Source: Firebase Console > Project Settings > General > Your apps > Web app
# Format: See values after calling firebaseConfig in the setup snippet.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
# [OPTIONAL] Only needed if you enable Google Analytics for Firebase.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# Firebase Admin SDK  [REQUIRED] [SERVER]
# ============================================
# Source: Firebase Console > Project Settings > Service accounts > Generate new private key
# The private key JSON contains project_id, client_email, and private_key.
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the full PEM key including -----BEGIN/END----- markers.
# Keep the surrounding quotes and use literal \n for newlines.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# Google Maps Platform  [REQUIRED] [CLIENT]
# ============================================
# Source: Google Cloud Console > APIs & Services > Credentials > Create API Key
# Required APIs: Maps JavaScript API, Directions API, Geocoding API, Places API
# Restrict the key to your domain in production.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# [OPTIONAL] Map ID for cloud-based map styling. Create at:
# Google Cloud Console > Google Maps Platform > Map Management
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your_google_maps_map_id_here

# ============================================
# Google Gemini API  [REQUIRED] [SERVER]
# ============================================
# Source: Google AI Studio — https://aistudio.google.com/apikey
# Used for pollution image analysis, report summarization.
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Vertex AI  [OPTIONAL] [SERVER]
# ============================================
# Only needed if using custom-trained prediction models on Vertex AI.
# Source: Google Cloud Console > Vertex AI > Endpoints
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ENDPOINT_ID=your_vertex_ai_endpoint_id_here

# ============================================
# Google Earth Engine  [OPTIONAL] [SERVER]
# ============================================
# Only needed if the satellite imagery layer feature is enabled.
# Source: https://earthengine.google.com/ — register and create a service account.
EARTH_ENGINE_SERVICE_ACCOUNT=earth-engine@your-project-id.iam.gserviceaccount.com
EARTH_ENGINE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_EE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
EARTH_ENGINE_PROJECT_ID=your-gcp-project-id

# ============================================
# BigQuery  [OPTIONAL] [SERVER]
# ============================================
# Only needed for historical analytics and batch prediction pipelines.
# Source: Google Cloud Console > BigQuery
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET_ID=vayudrishti_analytics
BIGQUERY_LOCATION=US

# ============================================
# Cloud Run / Cloud Functions  [OPTIONAL] [SERVER]
# ============================================
# Only needed if backend microservices are deployed separately.
CLOUD_RUN_SERVICE_URL=https://vayudrishti-api-xxxxxxxxxx-uc.a.run.app
CLOUD_FUNCTIONS_REGION=us-central1

# ============================================
# WhatsApp Business API  [OPTIONAL] [SERVER]
# ============================================
# Only needed if NEXT_PUBLIC_ENABLE_WHATSAPP_ALERTS=true.
# Source: Meta for Developers > WhatsApp > API Setup
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# ============================================
# Twilio  [OPTIONAL] [SERVER]
# ============================================
# Only needed if NEXT_PUBLIC_ENABLE_VOICE_REPORTING=true.
# Source: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# OpenWeather API  [OPTIONAL] [SERVER]
# ============================================
# Used by the prediction engine for weather-correlated AQI forecasting.
# Source: https://openweathermap.org/api — free tier available.
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ============================================
# CPCB / Government AQI Data  [OPTIONAL] [SERVER]
# ============================================
# Central Pollution Control Board data source for ground-truth AQI readings.
CPCB_API_BASE_URL=https://app.cpcbccr.com/ccr_docs/LATEST
CPCB_API_KEY=your_cpcb_api_key_if_required

# ============================================
# Application Configuration  [REQUIRED] [CLIENT]
# ============================================
NEXT_PUBLIC_APP_NAME=VayuDrishti
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DEFAULT_LOCALE=en
# Default map center (Delhi, India).
NEXT_PUBLIC_APP_DEFAULT_CITY=Delhi
NEXT_PUBLIC_APP_DEFAULT_LAT=28.6139
NEXT_PUBLIC_APP_DEFAULT_LNG=77.2090

# ============================================
# Feature Flags  [OPTIONAL] [CLIENT]
# ============================================
# Set to "true" to enable. Disabled by default to reduce costs and API calls.
NEXT_PUBLIC_ENABLE_VOICE_REPORTING=false
NEXT_PUBLIC_ENABLE_WHATSAPP_ALERTS=false
NEXT_PUBLIC_ENABLE_SATELLITE_LAYER=false
NEXT_PUBLIC_ENABLE_PREDICTION_ENGINE=false

# ============================================
# Rate Limiting  [OPTIONAL] [SERVER]
# ============================================
# Applied to API route handlers.
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# Image Upload  [OPTIONAL] [SERVER]
# ============================================
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/heic
IMAGE_COMPRESSION_QUALITY=0.8
