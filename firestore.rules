rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn()
        && (
          request.auth.token.role == role
          || (request.auth.token.roles is list && role in request.auth.token.roles)
        );
    }

    function isMunicipal() {
      return hasRole('municipal') || hasRole('reviewer') || hasRole('admin');
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /reports/{reportId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.location.lat is number
        && request.resource.data.location.lng is number
        && request.resource.data.status in ['pending', 'analyzing'];
      allow update: if isOwner(resource.data.userId) || isMunicipal();
      allow delete: if hasRole('admin');
    }

    match /hotspots/{hotspotId} {
      allow read: if signedIn();
      allow write: if isMunicipal();
    }

    match /alerts/{alertId} {
      allow read: if signedIn();
      allow write: if isMunicipal();
    }

    match /dispatches/{dispatchId} {
      allow read: if isMunicipal();
      allow write: if isMunicipal();
    }

    match /resources/{resourceId} {
      allow read: if isMunicipal();
      allow write: if isMunicipal();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId) || hasRole('admin');
      allow delete: if hasRole('admin');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

